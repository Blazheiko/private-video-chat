# Server runtime
NODE_ENV=development
PORT=3000

# Static assets path, resolved from apps/server package cwd when running package scripts.
STATIC_ROOT=../web/dist

# WebRTC ICE/TURN configuration
ICE_POLICY=all
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=
TURN_TTL_SEC=600

# Optional Coturn REST API credentials. When TURN_SECRET is set, the server
# generates temporary username/credential pairs for each joined participant.
# TURN_HOST is used to derive stun/turn/turns URLs when TURN_URLS is empty.
TURN_SECRET=
TURN_HOST=
